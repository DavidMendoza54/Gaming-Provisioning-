APP_ENV=production
APP_BASE_DOMAIN=apps.example.com
APP_PUBLIC_SCHEME=https
PROVISIONER_BACKEND=docker
DOCKER_NETWORK_NAME=tiny-provisioner-apps
MAX_ACTIVE_RESOURCES_PER_USER=1
DEFAULT_RESOURCE_TTL_HOURS=24
POSTGRES_USER=provisioner
POSTGRES_PASSWORD=change-this-long-random-password
POSTGRES_DB=provisioner
DATABASE_URL=postgresql+psycopg://provisioner:change-this-long-random-password@postgres:5432/provisioner
REDIS_URL=redis://redis:6379/0
SECRET_KEY=change-this-long-random-secret
ACME_EMAIL=you@example.com

